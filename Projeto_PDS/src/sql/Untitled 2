
	CREATE DATABASE IF NOT EXISTS mercado;

	USE mercado;

	CREATE TABLE IF NOT EXISTS usuarios (
	    id INT AUTO_INCREMENT PRIMARY KEY,  -- Chave primária com autoincremento
	    nome VARCHAR(100) NOT NULL,         -- Nome do usuário, não pode ser nulo
	    email VARCHAR(100) NOT NULL UNIQUE, -- Email do usuário, não pode ser nulo e deve ser único
		tipoUsuario VARCHAR(100) NOT NULL
	);

