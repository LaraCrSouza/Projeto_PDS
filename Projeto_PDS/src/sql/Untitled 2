	CREATE TABLE IF NOT EXISTS produto (
	codigo int NOT NULL PRIMARY KEY,
	nome varchar(255) NOT NULL,
	URL varchar(255) NOT NULL,
	marca varchar(255) NOT NULL,
	categorias varchar(255) NOT NULL,
	PesoBruto float,
	altura float,
	largura float,
	comprimento float,
	preco double NOT NULL
	);

